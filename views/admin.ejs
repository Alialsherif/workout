<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1f7a55" />
    <title><%= t.adminPanel %></title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="page-shell">
      <div class="lang-switcher" dir="ltr">
        <a class="lang-pill <%= lang === 'ar' ? 'active' : '' %>" href="<%= switchToArabicHref %>"><%= t.langArabic %></a>
        <a class="lang-pill <%= lang === 'en' ? 'active' : '' %>" href="<%= switchToEnglishHref %>"><%= t.langEnglish %></a>
      </div>

      <header class="hero compact">
        <div>
          <p class="eyebrow"><%= t.adminPanel %></p>
          <h1><%= t.manageWorkoutLevels %></h1>
          <p class="hero-copy"><%= t.adminIntro %></p>
        </div>
        <div class="hero-actions">
          <form action="/admin/logout" method="POST">
            <button class="button secondary" type="submit"><%= t.logout %></button>
          </form>
          <a class="button secondary" href="/"><%= t.backHome %></a>
        </div>
      </header>

      <div class="admin-layout">
        <section class="panel">
          <div class="section-heading">
            <h2><%= t.addNewLevel %></h2>
          </div>

          <% if (error) { %>
            <div class="alert"><%= error %></div>
          <% } %>

          <% if (success) { %>
            <div class="alert success"><%= success %></div>
          <% } %>

          <form class="form-grid" action="/admin/levels" method="POST">
            <div class="field">
              <label for="name"><%= t.levelName %></label>
              <input
                id="name"
                name="name"
                type="text"
                placeholder="<%= t.levelPlaceholder %>"
                dir="auto"
                required
              />
            </div>
            <button class="button" type="submit"><%= t.addLevel %></button>
          </form>
        </section>

        <section class="panel">
          <div class="section-heading">
            <h2><%= t.allLevels %></h2>
            <span class="pill"><%= levels.length %> <%= t.total %></span>
          </div>

          <% if (levels.length === 0) { %>
            <p class="muted"><%= t.noLevelsCreated %></p>
          <% } else { %>
            <div class="stack-list">
              <% levels.forEach((level) => { %>
                <div class="list-item">
                  <div>
                    <p class="list-title" dir="auto"><%= level.name %></p>
                    <p class="muted" dir="ltr">/levels/<%= level.id %></p>
                  </div>
                  <div class="list-actions">
                    <a class="button secondary" href="/levels/<%= level.id %>"><%= t.view %></a>
                    <a class="button" href="/admin/levels/<%= level.id %>"><%= t.manageExercises %></a>
                    <form action="/admin/levels/<%= level.id %>/delete" method="POST" onsubmit="return confirm('<%= t.deleteLevel %>?');">
                      <button class="button ghost-danger" type="submit"><%= t.deleteLevel %></button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>
      </div>

      <footer class="project-signature contact-footer">
        <p><%= t.footerMarketing %></p>
        <a class="button whatsapp-button" href="https://wa.me/201036178517" target="_blank" rel="noopener noreferrer"><%= t.contactWhatsApp %></a>
      </footer>
    </div>
  </body>
</html>
