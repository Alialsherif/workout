<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Workout Training System</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="page-shell">
      <header class="hero">
        <div>
          <p class="eyebrow">Workout Training System</p>
          <h1>Choose your training level</h1>
          <p class="hero-copy">
            Browse the available workout plans and open a level to start your
            session.
          </p>
        </div>
        <a class="button secondary" href="/admin/login">Open Admin Panel</a>
      </header>

      <section class="panel">
        <div class="section-heading">
          <h2>Available levels</h2>
          <span class="pill"><%= levels.length %> level(s)</span>
        </div>

        <% if (levels.length === 0) { %>
          <div class="empty-state">
            <p>No levels available yet.</p>
            <a class="button" href="/admin/login">Create the first level</a>
          </div>
        <% } else { %>
          <div class="level-grid">
            <% levels.forEach((level) => { %>
              <a class="level-card" href="/levels/<%= level.id %>">
                <span class="card-badge">Level <%= level.id %></span>
                <h3><%= level.name %></h3>
                <p>Open this plan and track your completed exercises.</p>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>

      <footer class="project-signature" dir="rtl">
        <p>قام بتنفيذ هذا المشروع البسيط المهندس علي الشريف</p>
      </footer>
    </div>
  </body>
</html>
