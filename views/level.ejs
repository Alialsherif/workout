<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1f7a55" />
    <title><%= level.name %> | <%= t.workoutPlan %></title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="page-shell">
      <div class="lang-switcher" dir="ltr">
        <a class="lang-pill <%= lang === 'ar' ? 'active' : '' %>" href="<%= switchToArabicHref %>"><%= t.langArabic %></a>
        <a class="lang-pill <%= lang === 'en' ? 'active' : '' %>" href="<%= switchToEnglishHref %>"><%= t.langEnglish %></a>
      </div>

      <header class="hero compact">
        <div>
          <p class="eyebrow"><%= t.trainingLevel %></p>
          <h1 dir="auto"><%= level.name %></h1>
          <p class="hero-copy"><%= t.levelIntro %></p>
        </div>
        <div class="hero-actions">
          <a class="button secondary" href="/"><%= t.backHome %></a>
        </div>
      </header>

      <section class="panel">
        <div class="section-heading">
          <h2><%= t.pendingExercises %></h2>
          <span class="pill"><span id="pending-count"><%= exercises.length %></span> <%= t.exerciseCount %></span>
        </div>

        <% if (exercises.length === 0) { %>
          <p class="muted"><%= t.noExercises %></p>
        <% } else { %>
          <div class="table-wrap">
            <table class="workout-table">
              <colgroup>
                <col class="col-exercise" />
                <col class="col-reps" />
                <col class="col-sets" />
                <col class="col-rest" />
                <col class="col-done" />
              </colgroup>
              <thead>
                <tr>
                  <th><%= t.exerciseName %></th>
                  <th><%= t.repsOrTime %></th>
                  <th><%= t.sets %></th>
                  <th><%= t.restTime %></th>
                  <th><%= t.done %></th>
                </tr>
              </thead>
              <tbody id="pending-exercises">
                <% exercises.forEach((exercise, index) => { %>
                  <tr data-exercise-id="<%= exercise.id %>" data-order="<%= index %>">
                    <td data-label="<%= t.exerciseName %>" dir="auto"><span class="table-cell-value"><%= exercise.name %></span></td>
                    <td data-label="<%= t.repsOrTime %>" dir="auto"><span class="table-cell-value"><%= exercise.reps_or_time %></span></td>
                    <td data-label="<%= t.sets %>" dir="auto"><span class="table-cell-value"><%= exercise.sets %></span></td>
                    <td data-label="<%= t.restTime %>" dir="auto"><span class="table-cell-value"><%= exercise.rest_time %></span></td>
                    <td data-label="<%= t.done %>">
                      <label class="checkbox-cell">
                        <input class="exercise-toggle" type="checkbox" value="<%= exercise.id %>" />
                        <span><%= t.complete %></span>
                      </label>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>

      <% if (exercises.length > 0) { %>
        <section class="panel completed-panel">
          <div class="section-heading">
            <h2><%= t.completedExercises %></h2>
            <span class="pill"><span id="completed-count">0</span> <%= t.exerciseCount %></span>
          </div>
          <p id="completed-empty" class="muted"><%= t.noCompletedExercises %></p>
          <div class="table-wrap completed-wrap" id="completed-wrap" hidden>
            <table class="workout-table">
              <colgroup>
                <col class="col-exercise" />
                <col class="col-reps" />
                <col class="col-sets" />
                <col class="col-rest" />
                <col class="col-done" />
              </colgroup>
              <thead>
                <tr>
                  <th><%= t.exerciseName %></th>
                  <th><%= t.repsOrTime %></th>
                  <th><%= t.sets %></th>
                  <th><%= t.restTime %></th>
                  <th><%= t.done %></th>
                </tr>
              </thead>
              <tbody id="completed-exercises"></tbody>
            </table>
          </div>
        </section>
      <% } %>

      <footer class="project-signature contact-footer">
        <p><%= t.footerMarketing %></p>
        <a class="button whatsapp-button" href="https://wa.me/201036178517" target="_blank" rel="noopener noreferrer"><%= t.contactWhatsApp %></a>
      </footer>
    </div>

    <% if (exercises.length > 0) { %>
      <script>
        (() => {
          const levelId = <%= level.id %>;
          const legacyCookieName = "level_progress_<%= level.id %>";
          const pendingBody = document.getElementById("pending-exercises");
          const completedBody = document.getElementById("completed-exercises");
          const pendingCount = document.getElementById("pending-count");
          const completedCount = document.getElementById("completed-count");
          const completedEmpty = document.getElementById("completed-empty");
          const completedWrap = document.getElementById("completed-wrap");
          const checkboxes = Array.from(document.querySelectorAll(".exercise-toggle"));
          let isSyncing = false;

          function readCookie(name) {
            const parts = document.cookie ? document.cookie.split("; ") : [];
            const part = parts.find((item) => item.startsWith(`${name}=`));
            return part ? decodeURIComponent(part.split("=").slice(1).join("=")) : "";
          }

          function clearCookie(name) {
            document.cookie = `${name}=; path=/; max-age=0; samesite=lax`;
          }

          function getLegacyCompletedIds() {
            const raw = readCookie(legacyCookieName);
            if (!raw) {
              return [];
            }

            return [...new Set(
              raw
                .split(",")
                .map((value) => Number(value))
                .filter((value) => Number.isInteger(value) && value > 0)
            )].sort((first, second) => first - second);
          }

          function refreshCounts() {
            pendingCount.textContent = pendingBody.querySelectorAll("tr").length;
            completedCount.textContent = completedBody.querySelectorAll("tr").length;
            const hasCompleted = completedBody.querySelectorAll("tr").length > 0;
            completedWrap.hidden = !hasCompleted;
            completedEmpty.hidden = hasCompleted;
          }

          function insertRowInOrder(container, row) {
            const rowOrder = Number(row.dataset.order);
            const rows = Array.from(container.querySelectorAll("tr"));
            const nextRow = rows.find((item) => Number(item.dataset.order) > rowOrder);

            if (nextRow) {
              container.insertBefore(row, nextRow);
              return;
            }

            container.appendChild(row);
          }

          function moveRow(checkbox) {
            const row = checkbox.closest("tr");
            if (!row) {
              return;
            }

            if (checkbox.checked) {
              row.classList.add("is-complete");
              insertRowInOrder(completedBody, row);
            } else {
              row.classList.remove("is-complete");
              insertRowInOrder(pendingBody, row);
            }

            refreshCounts();
          }

          function getCheckedIds() {
            return checkboxes
              .filter((checkbox) => checkbox.checked)
              .map((checkbox) => Number(checkbox.value))
              .filter((value) => Number.isInteger(value) && value > 0)
              .sort((first, second) => first - second);
          }

          function applyCompletedIds(completedIds) {
            const completedIdSet = new Set(completedIds);

            checkboxes.forEach((checkbox) => {
              checkbox.checked = completedIdSet.has(Number(checkbox.value));
              moveRow(checkbox);
            });
          }

          async function saveProgress() {
            if (isSyncing) {
              return;
            }

            isSyncing = true;

            try {
              const response = await fetch(`/api/levels/${levelId}/progress`, {
                method: "POST",
                headers: {
                  "Content-Type": "application/json"
                },
                body: JSON.stringify({
                  completedExerciseIds: getCheckedIds()
                })
              });

              if (!response.ok) {
                throw new Error("Failed to save progress.");
              }

              const payload = await response.json();
              applyCompletedIds(payload.completedExerciseIds || []);
              clearCookie(legacyCookieName);
            } catch (error) {
              console.error(error);
            } finally {
              isSyncing = false;
            }
          }

          async function loadProgress() {
            try {
              const response = await fetch(`/api/levels/${levelId}/progress`);
              if (!response.ok) {
                throw new Error("Failed to load progress.");
              }

              const payload = await response.json();
              const serverCompletedIds = Array.isArray(payload.completedExerciseIds)
                ? payload.completedExerciseIds
                : [];
              const legacyCompletedIds = getLegacyCompletedIds();
              const completedIds = serverCompletedIds.length > 0 ? serverCompletedIds : legacyCompletedIds;

              applyCompletedIds(completedIds);

              if (legacyCompletedIds.length > 0 && serverCompletedIds.length === 0) {
                await saveProgress();
              } else if (legacyCompletedIds.length > 0) {
                clearCookie(legacyCookieName);
              }
            } catch (error) {
              console.error(error);
              applyCompletedIds(getLegacyCompletedIds());
            }
          }

          checkboxes.forEach((checkbox) => {
            checkbox.addEventListener("change", () => {
              moveRow(checkbox);
              void saveProgress();
            });
          });

          refreshCounts();
          void loadProgress();
        })();
      </script>
    <% } %>
  </body>
</html>
